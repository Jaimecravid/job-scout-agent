# =============================================================================
# Job Scout Agent — Configuration Template
# =============================================================================
# HOW TO USE THIS FILE:
#   1. Make a copy of this file in the same folder.
#   2. Rename the copy to exactly:  .env  (with the dot, no .txt extension)
#   3. Fill in your credentials below — replace every value inside the quotes.
#   4. Save the file. Never share it or upload it anywhere.
#
# If you are on Windows and cannot see the file after renaming it,
# open File Explorer -> View -> check "File name extensions".
# =============================================================================


# -----------------------------------------------------------------------------
# GMAIL / IMAP SETTINGS
# The agent reads your inbox using the IMAP protocol over SSL.
# You do NOT need to give it your real Gmail password (see EMAIL_APP_PASSWORD).
# -----------------------------------------------------------------------------

# Leave this exactly as-is for Gmail.
IMAP_SERVER="imap.gmail.com"

# Leave this exactly as-is for Gmail SSL.
IMAP_PORT=993

# Your full Gmail address (the one that receives the job alert emails).
EMAIL_USER="your.email@gmail.com"

# An App Password is a 16-character code Google generates for you.
# Your real Gmail password will NOT work here.
#
# How to generate one (takes ~60 seconds):
#   1. Go to https://myaccount.google.com/security
#   2. Under "How you sign in to Google", click "2-Step Verification" (must be ON).
#   3. Scroll to the bottom and click "App passwords".
#   4. Choose App: "Mail" / Device: "Windows Computer" -> click Generate.
#   5. Copy the 16-character code (spaces don't matter) and paste it below.
EMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"


# -----------------------------------------------------------------------------
# GOOGLE GEMINI AI SETTINGS
# The agent uses Gemini 2.5 Flash to screen each job email against your profile.
# -----------------------------------------------------------------------------

# How to get your free Gemini API Key (takes ~2 minutes):
#   1. Go to https://aistudio.google.com/app/apikey
#   2. Click "Create API key" -> "Create API key in new project".
#   3. Copy the key and paste it below.
GEMINI_API_KEY="AIza..."


# -----------------------------------------------------------------------------
# TELEGRAM MOBILE ALERTS (Optional but recommended)
# When a MATCH is found, the agent will send an instant alert to your phone.
# If you leave these blank, only the Windows desktop notification will fire.
# -----------------------------------------------------------------------------

# STEP A — Create your bot (one minute):
#   1. Open Telegram on your phone and search for:  @BotFather
#   2. Send the message:  /newbot
#   3. Follow the prompts (choose any name and username for your bot).
#   4. BotFather will give you a token that looks like:  123456789:ABCdef...
#   5. Paste that token below.
TELEGRAM_BOT_TOKEN="123456789:ABCdefGHIjklMNOpqrSTUvwxYZ"

# STEP B — Get your personal Chat ID (one minute):
#   1. In Telegram, search for:  @userinfobot
#   2. Send it any message (e.g. "hi").
#   3. It will reply with your numeric ID, e.g.  987654321
#   4. Paste that number below.
TELEGRAM_CHAT_ID="987654321"